{
  "name": "ReportStream Development Environment",
  "image": "mcr.microsoft.com/azure-dev-cli-apps:latest",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17",
      "installMaven": false,
      "installGradle": true
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/python:1": {},
    "ghcr.io/devcontainers/features/terraform:1": {},
    "ghcr.io/robbert229/devcontainer-features/postgresql-client:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "ms-azuretools.vscode-docker",
        "ms-vscode.azure-account",
        "ms-azuretools.vscode-azurefunctions",
        "ms-azuretools.vscode-azurestorage",
        "ms-azuretools.vscode-azureappservice",
        "ms-azuretools.vscode-azureresourcegroups",
        "ms-azuretools.vscode-azureterraform",
        "ms-vscode.azure-repos",
        "ms-vscode.vscode-node-azure-pack",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-vscode.vscode-node-azure-pack",
        "ms-azuretools.vscode-azureterraform",
        "hashicorp.terraform",
        "ms-vscode-remote.remote-containers",
        "ms-vscode-remote.remote-ssh",
        "ms-vscode-remote.remote-ssh-edit",
        "ms-vscode-remote.remote-wsl",
        "ms-vscode-remote.vscode-remote-extensionpack",
        "redhat.vscode-yaml",
        "github.vscode-pull-request-github"
      ]
    }
  },
  "postCreateCommand": "git clone https://github.com/CDCgov/prime-reportstream.git && cd prime-reportstream/prime-router && ./cleanslate.sh"
  //"onCreateCommand": "cd prime-reportstream/prime-router && ./gradlew seedReportStreamDb && ./gradlew seedVault",
  //"postStartCommand": "cd prime-reportstream/prime-router && ./launch_backend.sh"
}
